---
layout: null
permalink: /voices/feed.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title | xml_escape }} Voices</title>
    <link>{{ '/voices/' | absolute_url }}</link>
    <atom:link href="{{ '/voices/feed.xml' | absolute_url }}" rel="self" type="application/rss+xml" />
    <description>{{ site.description | xml_escape }}</description>
    <language>{{ site.lang | default: "en" | xml_escape }}</language>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    {% assign feed_quotes = site.quotes | sort: "date" | reverse %}
    {% for quote in feed_quotes %}
      <item>
        <title>{{ quote.title | xml_escape }}</title>
        <link>{{ quote.url | absolute_url }}</link>
        <guid isPermaLink="true">{{ quote.url | absolute_url }}</guid>
        {% if quote.date %}
          <pubDate>{{ quote.date | date_to_rfc822 }}</pubDate>
        {% endif %}
        <description>{{ quote.excerpt | default: quote.content | strip_html | normalize_whitespace | xml_escape }}</description>
      </item>
    {% endfor %}
  </channel>
</rss>
